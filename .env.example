# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ── Banco de dados ────────────────────────────────────────────────────────────
# Desenvolvimento local: aponte para seu PostgreSQL local
# Produção (Supabase): use os dados de conexão do painel do projeto
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=billing_development
POSTGRES_STATEMENT_TIMEOUT=14s
DB_POOL_SIZE=20

# ── Cache / Jobs ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rails ─────────────────────────────────────────────────────────────────────
# Obtenha com: rails secret  (ou cat config/master.key em dev)
RAILS_MASTER_KEY=
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=debug

# ── Stripe ────────────────────────────────────────────────────────────────────
# Painel: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Asaas ─────────────────────────────────────────────────────────────────────
# Painel: https://www.asaas.com/config/integracoes
ASAAS_API_KEY=
# Secret configurado no webhook do Asaas (token de acesso livre)
ASAAS_WEBHOOK_SECRET=

# ── Webhooks de saída ─────────────────────────────────────────────────────────
# Secret compartilhado com o sistema cliente para verificar X-Billing-Signature
OMNICHANNEL_WEBHOOK_SECRET=

# ── IA (Claude) ───────────────────────────────────────────────────────────────
# Painel: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
