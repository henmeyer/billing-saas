<%= content_for :title, "Entrar" %>

<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <div class="text-3xl mb-2">💳</div>
    <h2 class="text-xl font-semibold text-gray-900">Entrar no Billing</h2>
    <p class="mt-1 text-sm text-gray-500">Gerencie sua receita recorrente</p>
  </div>

  <div class="card">
    <div class="card-body">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "form-input" %>
          </div>

          <div>
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, autocomplete: "current-password",
                  class: "form-input" %>
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
              <%= f.check_box :remember_me %>
              Lembrar
            </label>
            <%= link_to "Esqueci a senha", new_user_password_path,
                  class: "text-sm text-brand-600 hover:text-brand-700" %>
          </div>

          <%= f.submit "Entrar", class: "btn-primary w-full justify-center mt-2" %>
        </div>
      <% end %>
    </div>
  </div>

  <p class="mt-4 text-center text-sm text-gray-500">
    Não tem conta?
    <%= link_to "Criar conta", new_user_registration_path,
          class: "text-brand-600 hover:text-brand-700 font-medium" %>
  </p>
</div>
