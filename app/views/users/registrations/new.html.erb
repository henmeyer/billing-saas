<%= content_for :title, "Criar conta" %>

<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <div class="text-3xl mb-2">💳</div>
    <h2 class="text-xl font-semibold text-gray-900">Criar conta</h2>
    <p class="mt-1 text-sm text-gray-500">Comece a gerenciar sua receita</p>
  </div>

  <div class="card">
    <div class="card-body">
      <% if @errors&.any? %>
        <div class="alert-danger mb-4">
          <div>
            <% @errors.each do |error| %>
              <p><%= error %></p>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= form_tag users_path, method: :post do %>
        <div class="space-y-4">
          <div>
            <label class="form-label">Nome da empresa</label>
            <%= text_field_tag 'user[company_name]', nil,
                  placeholder: "Minha Empresa Ltda",
                  class: "form-input", required: true %>
          </div>

          <div>
            <label class="form-label">Seu nome</label>
            <%= text_field_tag 'user[name]', nil,
                  placeholder: "João Silva",
                  class: "form-input", required: true %>
          </div>

          <div>
            <label class="form-label">E-mail</label>
            <%= email_field_tag 'user[email]', nil,
                  placeholder: "joao@empresa.com",
                  class: "form-input", required: true %>
          </div>

          <div>
            <label class="form-label">Senha</label>
            <%= password_field_tag 'user[password]', nil,
                  placeholder: "Mínimo 8 caracteres",
                  class: "form-input", required: true %>
          </div>

          <div>
            <label class="form-label">Confirmar senha</label>
            <%= password_field_tag 'user[password_confirmation]', nil,
                  class: "form-input", required: true %>
          </div>

          <%= submit_tag "Criar conta", class: "btn-primary w-full justify-center mt-2" %>
        </div>
      <% end %>
    </div>
  </div>

  <p class="mt-4 text-center text-sm text-gray-500">
    Já tem conta?
    <%= link_to "Entrar", new_user_session_path,
          class: "text-brand-600 hover:text-brand-700 font-medium" %>
  </p>
</div>
